# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Public HTTPS URL where this backend is reachable from the internet.
# REQUIRED for GitHub / Jira webhooks (they POST to this URL when events
# happen). Optional during local-only dev.
#
# How to get one in dev:
#   - VS Code Dev Tunnels (recommended — built-in, no install):
#       Terminal → "Forward a Port" → choose 3000 → set visibility "Public"
#       → copy the https URL it gives you
#   - ngrok:
#       ngrok http 3000  →  copy the https URL
#
# Example:
#   PUBLIC_BASE_URL=https://hmkl21gb-3000.use2.devtunnels.ms
#
# After setting this, configure the webhook in GitHub / Jira pointing to:
#   GitHub: <PUBLIC_BASE_URL>/webhooks/github
#   Jira:   <PUBLIC_BASE_URL>/webhooks/jira
PUBLIC_BASE_URL=

# ── Database (Supabase Postgres + pgvector) ─────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── JWT (RS256) ─────────────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -w0 private.pem   # → JWT_PRIVATE_KEY
#   base64 -w0 public.pem    # → JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=base64_encoded_private_key
JWT_PUBLIC_KEY=base64_encoded_public_key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Bootstrap super-admin (seeded on first boot) ────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login
BOOTSTRAP_ADMIN_FULL_NAME=System Super Admin

# ── LLM providers (API keys only — model selection lives in DB) ─────
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=sk-proj-your_openai_key
ANTHROPIC_API_KEY=

# ── Jira (any project — discovered at seed time) ────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=AGNTX
JIRA_WEBHOOK_SECRET=your_jira_webhook_secret

# ── GitHub (any repo — validated at seed time) ──────────────────────
GITHUB_TOKEN=ghp_your_token
GITHUB_OWNER=your_github_owner
GITHUB_REPO=your_repo_name
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# ── Email (SMTP — Google Workspace by default) ──────────────────────
# This file is COMMITTED TO GIT. NEVER paste real credentials here —
# only placeholders. Real values go into your local `.env` (gitignored).
#
# For Gmail / Google Workspace:
#   1. Enable 2FA on the Google account: https://myaccount.google.com/security
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#      → App = "Mail", Device = "Other (SRE Agent)"
#   3. Paste the 16-char password into SMTP_PASS (no spaces)
#
# SMTP_SERVICE='gmail' is a nodemailer shortcut that auto-resolves
# host/port/secure. For other providers (Mailgun, SES, custom Postfix),
# leave SMTP_SERVICE empty and set SMTP_HOST/SMTP_PORT/SMTP_SECURE explicitly.
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your_google_app_password


# ── GCP Cloud Storage (incident attachments) ───────────────────────
#
# HACKATHON JUDGES: A testing-only GCP service account is included
# in the repo at apps/backend/.keys/gcp-credentials.json for your
# convenience. It has minimal permissions (Storage Object Creator +
# Viewer) on a sandbox bucket. This credential will be REVOKED after
# the event. In production, NEVER commit credentials to the repo.
#
# If you prefer to use your OWN GCP account:
#   1. Create a GCS bucket
#   2. Create a Service Account with roles:
#      - Storage Object Creator (roles/storage.objectCreator)
#      - Storage Object Viewer  (roles/storage.objectViewer)
#   3. Download the JSON key and update the values below
#
GCP_PROJECT_ID=agentx-492817
GCP_BUCKET_NAME=agentx-storage
GOOGLE_APPLICATION_CREDENTIALS=./.keys/gcp-credentials.json



# RFC 5322 from address: `Display Name <email@domain>` or just an email
EMAIL_FROM=Your Name <your_email@yourdomain.com>
EMAIL_APP_NAME=Your App Name
EMAIL_DEFAULT_COMPANY=Your Company Name
EMAIL_SUPPORT_EMAIL=support@yourdomain.com
EMAIL_COMPANY_ADDRESS=Your Company Address
TEAM_EMAIL=engineering@yourdomain.com

# ── Slack ───────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── RAG — codebase indexing ─────────────────────────────────────────
# Git URL the init script clones into a temporary folder, indexes into
# pgvector, and then deletes. Nothing is kept on disk after indexing —
# only the embeddings live in `rag_documents`. Change this to point at
# YOUR own codebase (any git URL the local git CLI can clone).
ECOMMERCE_REF_REPO_URL=https://github.com/reactioncommerce/reaction

# Optional override: if you already have the repo cloned somewhere and
# want the indexer to use THAT instead of cloning fresh, set an absolute
# path here. Leave empty to use the temporary clone managed by `npm run init`.
ECOMMERCE_REF_PATH=

# Path to a folder of `.log` files for the LOGS RAG collection (optional).
LOGS_PATH=

# ── Frontends ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_REALTIME_URL=ws://localhost:3000/realtime

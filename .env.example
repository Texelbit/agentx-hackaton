# ═══════════════════════════════════════════════════════════════════════
# SRE Incident Response Agent — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Legend:  [REQUIRED] = app won't start without it
#          [OPTIONAL] = has a sensible default or can be skipped
# ═══════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development                          # [OPTIONAL] development | production
PORT=3000                                     # [OPTIONAL] default 3000

# [OPTIONAL] Public HTTPS URL for webhooks. Required for GitHub/Jira
# webhook delivery. In dev, use VS Code Dev Tunnels or ngrok on :3000.
PUBLIC_BASE_URL=

# ── Database ────────────────────────────────────────────────────────
# [REQUIRED] Supabase Postgres connection string (pgvector must be enabled)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── JWT (RS256) ─────────────────────────────────────────────────────
# [REQUIRED] Base64-encoded RSA keypair. Auto-generated by `npm run init`.
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -w0 private.pem → JWT_PRIVATE_KEY
#   base64 -w0 public.pem  → JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=base64_encoded_private_key
JWT_PUBLIC_KEY=base64_encoded_public_key
JWT_ACCESS_EXPIRY=15m                         # [OPTIONAL] default 15m
JWT_REFRESH_EXPIRY=7d                         # [OPTIONAL] default 7d

# ── Bootstrap super-admin ───────────────────────────────────────────
# [REQUIRED] Created by the bootstrap seed on first boot.
BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login
BOOTSTRAP_ADMIN_FULL_NAME=System Super Admin

# ── LLM providers ───────────────────────────────────────────────────
# [REQUIRED] At least GEMINI + OPENAI for the default agent configuration.
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=sk-proj-your_openai_key
ANTHROPIC_API_KEY=                            # [OPTIONAL] only if using Claude

# ── Jira ────────────────────────────────────────────────────────────
# [REQUIRED] Any Jira Cloud project. Statuses are auto-discovered at seed time.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=AGNTX
JIRA_WEBHOOK_SECRET=your_jira_webhook_secret  # [OPTIONAL] for Jira→backend webhooks

# ── GitHub ──────────────────────────────────────────────────────────
# [REQUIRED] Fine-grained PAT with repo + webhook permissions.
GITHUB_TOKEN=ghp_your_token
GITHUB_OWNER=your_github_owner
GITHUB_REPO=your_repo_name
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret  # [REQUIRED] HMAC verification

# ── Email (SMTP) ───────────────────────────────────────────────────
# [REQUIRED] For incident notifications. Gmail App Password recommended.
#   1. Enable 2FA: https://myaccount.google.com/security
#   2. App Password: https://myaccount.google.com/apppasswords
#      → App = "Mail", Device = "Other (SRE Agent)"
#   3. Paste the 16-char password into SMTP_PASS (no spaces)
SMTP_SERVICE=gmail                            # [OPTIONAL] nodemailer shortcut
SMTP_HOST=smtp.gmail.com                      # [REQUIRED if no SMTP_SERVICE]
SMTP_PORT=587                                 # [REQUIRED if no SMTP_SERVICE]
SMTP_SECURE=false
SMTP_USER=your-email@yourdomain.com           # [REQUIRED]
SMTP_PASS=your_google_app_password            # [REQUIRED]

EMAIL_FROM=Your Name <your_email@yourdomain.com>  # [REQUIRED] sender address
EMAIL_APP_NAME=SRE Agent                      # [OPTIONAL]
EMAIL_DEFAULT_COMPANY=Your Company             # [OPTIONAL]
EMAIL_SUPPORT_EMAIL=support@yourdomain.com     # [OPTIONAL]
EMAIL_COMPANY_ADDRESS=Your Company Address     # [OPTIONAL]

# ── GCP Cloud Storage ──────────────────────────────────────────────
# [OPTIONAL] For uploading incident attachments to GCS.
#
# ⚠️  HACKATHON JUDGES: Testing credentials included at
# apps/backend/.keys/gcp-credentials.json (minimal permissions,
# revoked after event). Use your own by updating below.
GCP_PROJECT_ID=agentx-492817
GCP_BUCKET_NAME=agentx-storage
GOOGLE_APPLICATION_CREDENTIALS=./.keys/gcp-credentials.json

# ── Slack ──────────────────────────────────────────────────────────
# [OPTIONAL] Incoming webhook URL for Slack notifications.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── RAG — codebase indexing ────────────────────────────────────────
# [OPTIONAL] Git repo URL to index for RAG. Cloned, embedded, then deleted.
ECOMMERCE_REF_REPO_URL=https://github.com/reactioncommerce/reaction
ECOMMERCE_REF_PATH=                           # [OPTIONAL] local path override
LOGS_PATH=                                    # [OPTIONAL] .log files folder

# ── Frontends ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000             # [OPTIONAL] default localhost
VITE_REALTIME_URL=ws://localhost:3000/realtime # [OPTIONAL] default localhost

{
  "name": "@sre/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "prisma:generate": "node ../../scripts/with-env.mjs prisma generate",
    "prisma:migrate": "node ../../scripts/with-env.mjs prisma migrate dev",
    "prisma:migrate:deploy": "node ../../scripts/with-env.mjs prisma migrate deploy",
    "prisma:db:execute": "node ../../scripts/with-env.mjs prisma db execute --file ./prisma/init.sql --schema ./prisma/schema.prisma",
    "prisma:studio": "node ../../scripts/with-env.mjs prisma studio",
    "seed:bootstrap": "ts-node -r tsconfig-paths/register prisma/seeds/bootstrap.seed.ts",
    "seed:jira": "ts-node -r tsconfig-paths/register prisma/seeds/jira.seed.ts",
    "seed:github": "ts-node -r tsconfig-paths/register prisma/seeds/github.seed.ts",
    "seed:indexer": "ts-node -r tsconfig-paths/register prisma/seeds/indexer.seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "@sre/agent-core": "*",
    "@sre/llm-client": "*",
    "@sre/tool-use": "*",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "joi": "^17.13.3",
    "nodemailer": "^6.9.16",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
